<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:text="WATCHLISTE"
            android:letterSpacing="0.2"
            android:textColor="#FFD700"
            android:textSize="40sp"
            android:fontFamily="serif"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your personal movie watchlist"
            android:textColor="#B3B3B3"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="120dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewWatchlist"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="Enter Library"
            android:textSize="18sp"
            app:backgroundTint="#E50914"
            app:cornerRadius="4dp"
            app:rippleColor="#FFD700" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddMovie"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginTop="16dp"
            android:text="+ Add to Collection"
            android:textColor="#FFD700"
            app:strokeColor="#FFD700"
            app:cornerRadius="4dp" />

    </LinearLayout>
</ScrollView>